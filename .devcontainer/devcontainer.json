{
	"name": "Existing Docker Compose (Extend)",

	"dockerComposeFile": [
		"../docker-compose.yml"
	],

	"service": "app",

	"workspaceFolder": "/langchain_learning",

	"shutdownAction": "stopCompose",

	"postCreateCommand": "pip install poetry",

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"googlecloudtools.cloudcode",
				"charliermarsh.ruff"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.cwd": "/langchain_learning"
			}
		}
	},

	"remoteUser": "vscode",

	"updateRemoteUserUID": true
}
